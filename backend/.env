# MINIMAL .env for Local Development
# Only 16 essential variables

NODE_ENV=development
PORT=3001

# Database - CRITICAL: Use localhost NOT "postgres"
DB_HOST=localhost
DB_PORT=5432
DB_NAME=humor_memory_game
DB_USER=gameuser
DB_PASSWORD=gamepass123

# Redis - CRITICAL: Use localhost NOT "redis"  
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
JWT_SECRET=dev-secret-key-for-testing
SESSION_SECRET=dev-session-key-for-testing

# API Configuration
API_BASE_URL=/api
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
